{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "env": {
    "DATABASE_URL": {
      "description": "PostgreSQL connection string from Supabase"
    },
    "EMAIL_SERVICE": {
      "description": "Email service provider (gmail)"
    },
    "EMAIL_USER": {
      "description": "Email service username or sender address"
    },
    "EMAIL_PASSWORD": {
      "description": "Email service app-specific password"
    }
  }
}
